---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<form data-signup class:list={['flex gap-2 max-w-md mx-auto max-sm:flex-col', className]}>
  <input
    type="email"
    required
    placeholder="you@company.com"
    aria-label="Email address"
    class="flex-1 rounded-lg border border-white/15 bg-white/6 px-5 py-3.5 font-body text-cream placeholder:text-cream/40 outline-none transition focus:border-gold"
  />
  <button
    type="submit"
    class="rounded-lg bg-gold px-6 py-3.5 font-semibold text-navy-dark transition hover:bg-gold-light hover:-translate-y-px shrink-0"
  >
    Notify Me
  </button>
</form>

<script>
  document.querySelectorAll('[data-signup]').forEach(form => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input') as HTMLInputElement;
      const btn = form.querySelector('button') as HTMLButtonElement;
      if (input && btn) {
        btn.textContent = "You're on the list";
        btn.disabled = true;
        input.disabled = true;
        input.value = '';
        input.placeholder = 'Check your inbox for confirmation';
      }
    });
  });
</script>
