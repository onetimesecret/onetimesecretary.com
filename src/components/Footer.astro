---
const useCases = [
  { href: '/usecases/hr', label: 'HR & Onboarding' },
  { href: '/usecases/legal', label: 'Legal & Compliance' },
  { href: '/usecases/it-security', label: 'IT & Security' },
  { href: '/usecases/healthcare', label: 'Healthcare' },
  { href: '/usecases/journalism', label: 'Journalism' },
  { href: '/usecases/insurance', label: 'Insurance' },
];

const product = [
  { href: '/#how-it-works', label: 'How It Works' },
  { href: '/#features', label: 'Features' },
  { href: '/#comparison', label: 'vs. Classic OTS' },
  { href: '/#signup', label: 'Early Access' },
];

const ots = [
  { href: 'https://onetimesecret.com', label: 'onetimesecret.com', external: true },
  { href: 'https://onetimesecret.com/info/security', label: 'Security', external: true },
  { href: 'https://onetimesecret.com/info/privacy', label: 'Privacy', external: true },
  { href: 'https://docs.onetimesecret.com', label: 'API Docs', external: true },
];
---

<footer class="bg-navy-dark pt-20 pb-10 text-cream">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-16 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr]">

      <!-- Brand -->
      <div>
        <a href="/" class="font-display text-lg text-cream no-underline">Secretary Links</a>
        <p class="mt-4 max-w-[280px] text-sm text-cream/50 leading-relaxed">
          Secure collection links by Onetime Secret. Generate a link, collect what you need, then it's gone forever.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="mb-4 font-body text-xs font-medium uppercase tracking-widest text-cream/40">Product</h4>
        <ul class="list-none space-y-2">
          {product.map(link => (
            <li><a href={link.href} class="text-sm text-cream/65 hover:text-gold no-underline transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Use Cases -->
      <div>
        <h4 class="mb-4 font-body text-xs font-medium uppercase tracking-widest text-cream/40">Use Cases</h4>
        <ul class="list-none space-y-2">
          {useCases.map(link => (
            <li><a href={link.href} class="text-sm text-cream/65 hover:text-gold no-underline transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Onetime Secret -->
      <div>
        <h4 class="mb-4 font-body text-xs font-medium uppercase tracking-widest text-cream/40">Onetime Secret</h4>
        <ul class="list-none space-y-2">
          {ots.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-cream/65 hover:text-gold no-underline transition-colors"
                {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-4 border-t border-white/6 pt-8 text-xs text-cream/35">
      <span>&copy; {new Date().getFullYear()} Onetime Secret. All rights reserved.</span>
      <span>onetimesecretary.com</span>
    </div>
  </div>
</footer>
