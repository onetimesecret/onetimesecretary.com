---
const links = [
  { href: '/#how-it-works', label: 'How It Works' },
  { href: '/#use-cases', label: 'Use Cases' },
  { href: '/#features', label: 'Features' },
  { href: '/#comparison', label: 'vs. Classic OTS' },
];
---

<nav
  data-nav
  class="fixed top-0 inset-x-0 z-50 py-4 transition-all duration-300
         [&.scrolled]:bg-navy/97 [&.scrolled]:shadow-[0_1px_0_rgba(255,255,255,0.06)]
         [&.scrolled]:py-2 [&.scrolled]:backdrop-blur-lg"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 font-display text-xl text-cream no-underline">
      <svg class="size-8" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        <path d="M8 20 L16 10 L20 14 L24 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M24 8 L24 13 M24 8 L19 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="16" cy="22" r="2" fill="currentColor" opacity="0.4"/>
      </svg>
      Secretary Links
    </a>

    <!-- Mobile toggle -->
    <button
      data-nav-toggle
      class="lg:hidden p-2 text-cream"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <!-- Links -->
    <ul
      data-nav-links
      class="hidden lg:flex items-center gap-8 list-none
             max-lg:absolute max-lg:top-full max-lg:inset-x-0
             max-lg:flex-col max-lg:bg-navy max-lg:p-6 max-lg:gap-4"
    >
      {links.map(link => (
        <li>
          <a href={link.href} class="text-sm font-medium text-cream/70 hover:text-cream transition-colors no-underline">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://onetimesecret.com"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 rounded-md border border-teal/20 bg-teal/8 px-3 py-1 text-xs font-medium text-teal no-underline"
        >
          Onetime Secret
        </a>
      </li>
      <li>
        <a
          href="/#signup"
          class="inline-flex items-center gap-1 rounded-md bg-gold px-5 py-2 text-sm font-semibold text-navy-dark no-underline transition hover:bg-gold-light hover:-translate-y-px"
        >
          Get Early Access
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const links = document.querySelector('[data-nav-links]');
  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('hidden') === false;
    links?.classList.toggle('flex', open);
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
