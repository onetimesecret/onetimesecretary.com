---
interface Props {
  id?: string;
  variant?: 'default' | 'dark' | 'navy-light' | 'cream-dark';
  class?: string;
}

const { id, variant = 'default', class: className = '' } = Astro.props;

const bgClasses: Record<string, string> = {
  default: 'bg-cream text-text-primary',
  dark: 'bg-navy text-cream',
  'navy-light': 'bg-navy-light text-cream',
  'cream-dark': 'bg-cream-dark text-text-primary',
};
---

<section id={id} class:list={['py-24 lg:py-32', bgClasses[variant], className]}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <slot />
  </div>
</section>
