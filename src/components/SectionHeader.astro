---
interface Props {
  subtitle?: string;
}

const { subtitle } = Astro.props;
---

<div class="mx-auto mb-12 max-w-2xl text-center" data-reveal>
  <h2 class="text-3xl sm:text-4xl lg:text-5xl"><slot /></h2>
  {subtitle && (
    <p class="mt-4 text-lg text-text-secondary leading-relaxed" set:html={subtitle} />
  )}
</div>
